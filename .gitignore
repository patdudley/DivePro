# Dependencies
node_modules/
.pnpm-store/
.yarn/

# Build output / local servers
dist/
build/
.cache/
.parcel-cache/
.vite/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment / secrets
.env
.env.*
!.env.example
.DS_Store

# Python scratch / cache
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
scripts/.cache/

# Generated large raw data dumps
*.grib
*.grib2
*.nc
*.hdf
*.h5
*.tif
*.tiff
*.mbtiles
*.pmtiles

# Temporary capture/output folders
outputs/
tmp/
temp/

# Parallel-work scratch (see CLAUDE.md)
trees/
.claude/worktrees/

# Wind map: only the cropped frames under data/wind-cropped/ are served.
# The full-resolution NOAA GFS originals are large (~12MB each) and unused —
# keep them out of the repo.
data/wind-san-diego-f*.json
data/wind-san-diego-manifest.json
data/wind-san-diego.json

# Output of scripts/build_gfs_wind_tiles.py — experimental tile pipeline,
# nothing on the site loads it. Keep the generated tiles out of the repo.
public/wind/

# Scripps frames are published as a replace-in-place GitHub Release asset.
# Never commit dated or latest camera images into public Git history.
camera-snapshots/scripps-pier*.jpg
camera-snapshots/scripps-pier*.jpeg
camera-snapshots/scripps-pier*.png
scripps-camera-batch.json
